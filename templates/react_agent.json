{
  "$schema": "../.phtnai/PHTN-AGENT-SCHEMA_v2.json",
  "agent_id": "react-agent-template",
  "name": "ReAct Agent Template",
  "description": "ReAct (Reasoning and Acting) agent template for complex multi-step tasks",
  "version": "1.0.0",
  "category": "REASONING",
  "tags": ["template", "react", "reasoning", "tools"],
  
  "execution_config": {
    "pattern": "REACT",
    "max_iterations": 10,
    "timeout_ms": 120000,
    "enable_streaming": true,
    "react_config": {
      "thought_prefix": "Thought:",
      "action_prefix": "Action:",
      "observation_prefix": "Observation:",
      "final_answer_prefix": "Final Answer:",
      "max_reasoning_steps": 8
    }
  },
  
  "llm_config": {
    "primary_model": {
      "provider": "openai",
      "model_id": "gpt-4-turbo-preview",
      "temperature": 0.3,
      "max_tokens": 4096
    },
    "fallback_models": [
      {
        "provider": "anthropic",
        "model_id": "claude-3-opus-20240229",
        "temperature": 0.3,
        "max_tokens": 4096
      }
    ],
    "routing_strategy": "FALLBACK"
  },
  
  "system_prompt": "You are an intelligent agent that uses the ReAct framework to solve problems.\n\nFor each step:\n1. Thought: Analyze the current situation and decide what to do next\n2. Action: Choose and execute a tool if needed\n3. Observation: Review the result of your action\n\nRepeat until you have enough information to provide a final answer.\n\nAlways think step by step and explain your reasoning.",
  
  "input_schema": {
    "content_types": ["TEXT", "STRUCTURED_DATA"]
  },
  
  "output_schema": {
    "content_types": ["TEXT", "STRUCTURED_DATA"],
    "format": {
      "include_reasoning": true
    }
  },
  
  "tools": [],
  
  "memory_config": {
    "short_term": {
      "enabled": true,
      "max_entries": 100
    },
    "episodic": {
      "enabled": true,
      "max_episodes": 30
    }
  },
  
  "guardrails_config": {
    "enforcement_mode": "enforce",
    "input_guardrails": {
      "prompt_injection_detection": {
        "enabled": true,
        "action": "block"
      }
    }
  },
  
  "resilience_config": {
    "retry": {
      "enabled": true,
      "max_attempts": 3,
      "backoff_strategy": "exponential"
    },
    "timeout": {
      "default_ms": 30000,
      "llm_ms": 60000
    }
  },
  
  "observability_config": {
    "tracing": {
      "enabled": true
    },
    "logging": {
      "level": "DEBUG"
    }
  }
}
